# LLM API Keys (set the ones you need)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Local model endpoints (optional)
OLLAMA_API_BASE=http://localhost:11434

# Database (default: SQLite in project dir — used as fallback if Supabase not configured)
DATABASE_URL=sqlite+aiosqlite:///./agent_fleet.db

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Concurrency
FLEET_MAX_CONCURRENT_TASKS=5
